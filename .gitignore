# === TALIA ===

# Dati sensibili: PDF/atti grezzi con possibili dati nominativi (mai nel repo)
data/raw/
*.pdf

# Fascicoli reali in data/samples/<id numerico>/ (PDF scaricati + report generati:
# quest'ultimi contengono dati estratti dai PDF — firmatari, oggetti — quindi non
# meno sensibili dei PDF stessi). I campioni sintetici/anonimizzati per i test
# restano tracciati (nomi non numerici, es. fascicolo_coerente/, fascicolo_critico/).
data/samples/[0-9]*/

# Log delle run di analisi (contengono dati personali)
logs/
# (i campioni anonimizzati in data/samples/ vanno aggiunti a mano con `git add -f`)

# Segreti / configurazione locale
.env
.env.*
!.env.example

# Database locali (inclusi sidecar WAL di sqlite)
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Ambienti virtuali
.venv/
venv/
env/
ENV/

# Test / coverage / cache
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# Modelli / artefatti pesanti (LLM, embeddings, vector store)
models/
*.bin
*.gguf
*.safetensors
.cache/

# === Editor / OS ===
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# === Tooling agenti locali (non parte del progetto) ===
.agents/
skills-lock.json
.claude/settings.local.json
*.db.bak-*
