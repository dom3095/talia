# === TALIA ===

# Dati sensibili: PDF/atti grezzi con possibili dati nominativi (mai nel repo)
data/raw/
*.pdf

# Log delle run di analisi (contengono dati personali)
logs/
# (i campioni anonimizzati in data/samples/ vanno aggiunti a mano con `git add -f`)

# Metadati/report generati per i fascicoli reali in data/samples/<id>/ (script
# prepara_fascicoli_candidati.py, `talia analizza`): contengono dati estratti dai
# PDF (firmatari, oggetti, motivazioni) — non meno sensibili dei PDF stessi.
fonte.json
report.md
report.json

# Segreti / configurazione locale
.env
.env.*
!.env.example

# Database locali (inclusi sidecar WAL di sqlite)
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.installed.cfg
*.egg

# Ambienti virtuali
.venv/
venv/
env/
ENV/

# Test / coverage / cache
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/

# Modelli / artefatti pesanti (LLM, embeddings, vector store)
models/
*.bin
*.gguf
*.safetensors
.cache/

