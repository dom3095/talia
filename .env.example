# === TALIA — variabili d'ambiente (copia in .env, mai committare .env) ===

# Lingua OCR Tesseract (deve essere installata nel sistema: ita).
TALIA_LINGUA_OCR=ita

# Percorso del database locale (Modulo 2/3). Default: SQLite in data/.
# TALIA_DB_URL=sqlite:///data/talia.db

# Endpoint/parametri LLM locale (Modulo 1 check 3, TAL-11). Nessuna chiamata a
# pagamento di default. Lasciare vuoto finché non implementato.
# TALIA_LLM_MODELLO=
# TALIA_LLM_ENDPOINT=
